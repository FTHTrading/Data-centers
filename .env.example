# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/unykorn_dc_os?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI / LLM (optional — agents degrade gracefully without this) ─────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Local path used to store uploaded attachments
FILE_STORAGE_PATH="./uploads"

# ─── Sourcing / Scraping ──────────────────────────────────────────────────────
# Comma-separated list of allowed scrape hostnames (security allow-list)
SCRAPE_ALLOWED_HOSTS=""

# ─── Misc ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
